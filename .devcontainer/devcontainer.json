{
  "name": "DiffusionNet",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "target": "devcontainer"
  },
  "runArgs": ["--gpus", "all"],
  "workspaceFolder": "/workspaces/diffusion-net",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/diffusion-net,type=bind",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter"
      ]
    }
  },
  "overrideCommand": true
}